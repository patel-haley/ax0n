{
  "name": "cortex",
  "publisher": "patel-haley",
  "displayName": "Cortex",
  "description": "Local-first AI memory for your IDE. Captures context as you work and surfaces it automatically in Cursor and Codex via MCP. No re-explaining your stack.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cortex.capture",
        "title": "Cortex: Capture Selection"
      },
      {
        "command": "cortex.search",
        "title": "Cortex: Search Memories"
      },
      {
        "command": "cortex.copyMcpConfig",
        "title": "Cortex: Copy Cursor MCP Config"
      },
      {
        "command": "cortex.showSetup",
        "title": "Cortex: Setup"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cortex-sidebar",
          "title": "Cortex",
          "icon": "media/cortex-icon.svg"
        }
      ]
    },
    "views": {
      "cortex-sidebar": [
        {
          "type": "webview",
          "id": "cortex.sidebarView",
          "name": "Cortex",
          "icon": "media/cortex-icon.svg",
          "contextualTitle": "Cortex"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cortex.capture",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Cortex",
      "properties": {
        "cortex.ollamaModel": {
          "type": "string",
          "default": "llama3",
          "markdownDescription": "Ollama model used to summarize captures before embedding. Requires a running Ollama instance at `http://localhost:11434`. Set to an empty string to disable summarization."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node --test",
    "lint": "eslint src --ext ts",
    "mcp": "node out/mcp-server.js",
    "mcp:rebuild": "npm rebuild better-sqlite3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.x",
    "@types/vscode": "^1.88.0",
    "@typescript-eslint/eslint-plugin": "^7.x",
    "@typescript-eslint/parser": "^7.x",
    "eslint": "^8.x",
    "ts-node": "^10.9.2",
    "typescript": "^5.x"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0"
  }
}
