{
  "name": "ax0n",
  "publisher": "patel-haley",
  "displayName": "Ax0n",
  "description": "Local-first AI memory for your IDE. Automatic context injection. No re-explaining your stack.",
  "icon": "media/ax0n.jpg",
  "version": "1.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/patel-haley/ax0n.git"
  },
  "bugs": {
    "url": "https://github.com/patel-haley/ax0n/issues"
  },
  "homepage": "https://github.com/patel-haley/ax0n#readme",
  "keywords": [
    "memory",
    "mcp",
    "embeddings",
    "cursor",
    "codex",
    "local",
    "ai"
  ],
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ax0n.capture",
        "title": "Ax0n: Capture Selection"
      },
      {
        "command": "ax0n.search",
        "title": "Ax0n: Search Memories"
      },
      {
        "command": "ax0n.showTopResult",
        "title": "Ax0n: Show Top Result for Current File"
      },
      {
        "command": "ax0n.listMemories",
        "title": "Ax0n: List Memories"
      },
      {
        "command": "ax0n.deleteMemory",
        "title": "Ax0n: Delete Memory"
      },
      {
        "command": "ax0n.clearMemories",
        "title": "Ax0n: Clear All Memories"
      },
      {
        "command": "ax0n.copyMcpConfig",
        "title": "Ax0n: Copy Cursor MCP Config"
      },
      {
        "command": "ax0n.showSetup",
        "title": "Ax0n: Setup"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ax0n-sidebar",
          "title": "Ax0n",
          "icon": "media/ax0n-icon.svg"
        }
      ]
    },
    "views": {
      "ax0n-sidebar": [
        {
          "type": "webview",
          "id": "ax0n.sidebarView",
          "name": "Ax0n",
          "icon": "media/ax0n-icon.svg",
          "contextualTitle": "Ax0n"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ax0n.capture",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Ax0n",
      "properties": {
        "ax0n.ollamaModel": {
          "type": "string",
          "default": "llama3",
          "markdownDescription": "Ollama model used to summarize captures before embedding. Requires a running Ollama instance at `http://localhost:11434`. Set to an empty string to disable summarization."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node --test",
    "lint": "eslint src --ext ts",
    "mcp": "node out/mcp-server.js",
    "mcp:rebuild": "npm rebuild better-sqlite3",
    "vsix": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vscode/vsce": "^3.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.x",
    "@types/vscode": "^1.88.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "^7.x",
    "@typescript-eslint/parser": "^7.x",
    "eslint": "^8.x",
    "ts-node": "^10.9.2",
    "typescript": "^5.x"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0"
  }
}
